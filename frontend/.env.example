# Frontend environment variables — loaded by the frontend container via docker-compose,
# and by Next.js when running standalone (outside Docker).
# Copy this file to `frontend/.env` (Docker) or `frontend/.env.local` (standalone) and fill in real values.
# NEXT_PUBLIC_* variables are exposed to the browser — do not put secrets here.
# The following belong in backend/.env only — do not add them here:
#   SUPABASE_URL, SUPABASE_SERVICE_ROLE_KEY, SUPABASE_DB_PASSWORD,
#   ANTHROPIC_API_KEY, DATABASE_URL

# ─── Supabase ────────────────────────────────────────────────────────────────

# Project URL (e.g. https://<project-ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Backend ─────────────────────────────────────────────────────────────────

# Base URL of the backend API
NEXT_PUBLIC_API_URL=http://localhost:8000

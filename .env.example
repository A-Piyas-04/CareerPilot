# Root environment variables — used by docker-compose for both services.
# Copy this file to `.env` and fill in real values before running `docker compose up`.

# ─── Supabase ────────────────────────────────────────────────────────────────

# Project URL (e.g. https://<project-ref>.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key — KEEP SECRET, server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database password (used when connecting directly via DATABASE_URL)
SUPABASE_DB_PASSWORD=your-supabase-db-password

# ─── Backend ─────────────────────────────────────────────────────────────────

# Public URL the frontend uses to reach the backend API
NEXT_PUBLIC_API_URL=http://localhost:8000

# Direct Postgres connection string (optional; required if DATABASE_URL is used in config)
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# Comma-separated list of allowed CORS origins (defaults to localhost:3000 if unset)
# CORS_ORIGINS=http://localhost:3000,https://your-production-domain.com

# Enable FastAPI debug mode (true | false)
DEBUG=false

# ─── AI / ML ─────────────────────────────────────────────────────────────────

# Anthropic API key for Claude — KEEP SECRET
ANTHROPIC_API_KEY=your-anthropic-api-key

# Hugging Face token — used to download sentence-transformers models (read-only token is fine)
HF_TOKEN=your-huggingface-token

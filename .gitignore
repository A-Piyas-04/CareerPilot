# CareerPilot — project-wide git ignore rules
# Single source of truth for both frontend (Next.js) and backend (Python).

# ── Environment / secrets ──
.env
.env.*
# ...but keep committed example files
!.env*.example

# ── Node / frontend dependencies ──
node_modules/
.pnp.*
.yarn/

# ── Next.js build output ──
.next/
out/
build/
dist/
coverage/
*.tsbuildinfo
next-env.d.ts
.vercel

# ── Python / backend ──
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
.pytest_cache/
.coverage
htmlcov/

# ── Python virtual environments ──
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/
pyvenv.cfg

# ── Logs ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# ── IDE / OS ──
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Misc ──
*.pem

.puku/

# ignore a folder named myDocs
myDocs/
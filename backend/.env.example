# Backend environment variables
# Copy this file to `.env` and replace the placeholder values.

# Base URL of the backend API
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase project URL (e.g. https://<project-ref>.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key — KEEP SECRET, server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Anthropic API key for Claude API access
ANTHROPIC_API_KEY=your-anthropic-api-key

# Hugging Face token — faster model downloads for CV embeddings (read-only token is enough)
HF_TOKEN=your-huggingface-token

# Backend environment variables — loaded by the backend container via docker-compose,
# and by the backend process when running standalone (outside Docker).
# Copy this file to `backend/.env` and fill in real values.

# ─── Supabase ────────────────────────────────────────────────────────────────

# Project URL (e.g. https://<project-ref>.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key — KEEP SECRET, server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Anon / public key (needed by some server-side Supabase client calls)
SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Database ────────────────────────────────────────────────────────────────

# Direct Postgres connection string (used by Alembic migrations and any direct DB access)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ─── API settings ────────────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins (defaults to localhost:3000 if unset)
# CORS_ORIGINS=http://localhost:3000,https://your-production-domain.com

# Enable FastAPI debug mode (true | false)
DEBUG=false

# ─── AI / ML ─────────────────────────────────────────────────────────────────

# Google Gemini API key — KEEP SECRET, required for /api/v1/resumes/answer
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Embedding backend: "gemini" (default, no local model download)
# Optional future backends may include "transformers", etc.
EMBEDDING_BACKEND=gemini

# Analysis backend for skill extraction and CV analysis.
ANALYSIS_BACKEND=gemini

# Gemini embedding model (v1beta-safe default: models/embedding-001)
GEMINI_EMBEDDING_MODEL=models/embedding-001

# Target vector dimension — must match Supabase resume_chunks.embedding (vector(384))
# and match_resume_chunks RPC. Gemini uses output_dimensionality to produce 384-dim vectors.
EMBEDDING_VECTOR_DIM=384

# Active pgvector column for storage and retrieval (production default: embedding).
# embedding_new is only for optional Alembic backfill migrations.
EMBEDDING_ACTIVE_COLUMN=embedding

# Guardrail: if true, retrieval fails when vector dimensions mismatch.
# Set to false temporarily only during controlled migration windows.
RETRIEVAL_REQUIRE_DIM_MATCH=true

# ─── External job-search providers (JSearch via RapidAPI) ────────────────────

# JSearch API key (LinkedIn/Indeed/Glassdoor aggregator).
# Get one at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Leave blank to disable live search; the manual-paste source still works.
JSEARCH_API_KEY=

# RapidAPI host header value (override only if RapidAPI rotates it)
JSEARCH_API_HOST=jsearch.p.rapidapi.com

# JSearch API base URL (search requests go to {JSEARCH_BASE_URL}/search)
JSEARCH_BASE_URL=https://jsearch.p.rapidapi.com

# Legacy aliases (still supported): RAPIDAPI_KEY, RAPIDAPI_HOST

# Backend environment variables — loaded by the backend container via docker-compose,
# and by the backend process when running standalone (outside Docker).
# Copy this file to `backend/.env` and fill in real values.

# ─── Supabase ────────────────────────────────────────────────────────────────

# Project URL (e.g. https://<project-ref>.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key — KEEP SECRET, server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Anon / public key (needed by some server-side Supabase client calls)
SUPABASE_ANON_KEY=your-supabase-anon-key

# ─── Database ────────────────────────────────────────────────────────────────

# Direct Postgres connection string (used by Alembic migrations and any direct DB access)
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ─── API settings ────────────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins (defaults to localhost:3000 if unset)
# CORS_ORIGINS=http://localhost:3000,https://your-production-domain.com

# Enable FastAPI debug mode (true | false)
DEBUG=false

# ─── AI / ML ─────────────────────────────────────────────────────────────────

# Google Gemini API key — KEEP SECRET, required for /api/v1/resumes/answer
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Embedding backend: "hashing" (default, no download, fast Docker build)
#                    "transformers" (semantic quality, requires manual install — see below)
#
# To enable semantic embeddings:
#   1. pip install sentence-transformers   (NOT in requirements.txt — pulls PyTorch ~2 GB)
#   2. Change the value below to: transformers
EMBEDDING_BACKEND=hashing

# HF_TOKEN: removed — sentence-transformers replaced by HashingVectorizer

# ─── External job-search providers ───────────────────────────────────────────

# RapidAPI key for the JSearch endpoint (LinkedIn/Indeed/Glassdoor aggregator).
# Get one at https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch
# Leave blank to disable the JSearch source; the manual-paste source still works.
RAPIDAPI_KEY=

# JSearch host (override only if RapidAPI rotates it)
RAPIDAPI_HOST=jsearch.p.rapidapi.com

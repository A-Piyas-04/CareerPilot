# Backend environment variables — used when running the backend standalone (outside Docker).
# Copy this file to `.env` in this directory and fill in real values.

# ─── Supabase ────────────────────────────────────────────────────────────────

# Project URL (e.g. https://<project-ref>.supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key — KEEP SECRET, server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Anon / public key (needed by some server-side Supabase client calls)
SUPABASE_ANON_KEY=your-supabase-anon-key

# Direct Postgres connection string (optional)
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# ─── API settings ────────────────────────────────────────────────────────────

# Comma-separated list of allowed CORS origins (defaults to localhost:3000 if unset)
# CORS_ORIGINS=http://localhost:3000,https://your-production-domain.com

# Enable FastAPI debug mode (true | false)
DEBUG=false

# ─── AI / ML ─────────────────────────────────────────────────────────────────

# Anthropic API key for Claude — KEEP SECRET, required for /api/v1/resumes/answer
ANTHROPIC_API_KEY=your-anthropic-api-key

# Embedding backend: "hashing" (default, no download) or "transformers" (semantic, ~90 MB download)
# Use "transformers" for better RAG quality; requires: pip install sentence-transformers
EMBEDDING_BACKEND=hashing

# Hugging Face token — optional, only needed for gated HF models
# HF_TOKEN=your-huggingface-token
